# AnyFrame Python SDK — environment variables
#
# The SDK reads these from the environment (or a .env file in the current
# working directory) when you construct AnyFrame() with no arguments.

# Required: your AnyFrame API key. Mint one at https://anyfrm.com/settings/tokens
ANYFRAME_API_KEY=afm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the control-plane URL (defaults to api.anyfrm.com)
# ANYFRAME_BASE_URL=https://api.anyfrm.com

# Optional: SDK log level (defaults to INFO). Set to DEBUG for request tracing.
# ANYFRAME_LOG_LEVEL=DEBUG
